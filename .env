# =============================================================================
# نمونه متغیرهای محیطی (توسعه محلی و Cloudflare Pages)
# توکن‌ها و تنظیمات حساس در production از متغیرهای محیطی Cloudflare خوانده می‌شوند.
# این فایل را کپی کرده و به .env تغییر نام دهید؛ هرگز کلیدهای واقعی را commit نکنید.
# =============================================================================

# --- اجباری ---
# رشته اتصال PostgreSQL (توصیه: Neon PostgreSQL برای Cloudflare Pages)
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# --- اجباری ---
# رمز JWT (حداقل ۳۲ کاراکتر تصادفی)
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# --- اجباری: احراز هویت ادمین ---
# رمز پیش‌فرض مدیر کل (SUPER_ADMIN). در اولین ورود باید تغییر کند.
SUPER_ADMIN_PASSWORDS=SuperDefaultPass123!

# رمز پیش‌فرض اپراتورها (OPERATOR). در اولین ورود هر اپراتور باید تغییر کند.
OPERATOR_ADMIN_PASSWORDS=OperatorDefaultPass123!

# --- اختیاری: ربات‌ها (در Cloudflare از env bindings استفاده می‌شود) ---
# توکن ربات تلگرام — اولویت نسبت به system_settings دارد
TOKEN_TELEGRAM=optional-dev-token

# توکن ربات بله — اولویت نسبت به system_settings دارد
TOKEN_BALE=optional-dev-token

# --- اختیاری: درگاه پرداخت (در Cloudflare از env bindings استفاده می‌شود) ---
# مرچنت کد / توکن درگاه (زرین‌پال یا پی‌پینگ) — اولویت نسبت به system_settings دارد
ZARINPAL_API=optional-dev-merchant-or-token

# انتخاب درگاه: zarinpal | payping | test
PAYMENT_GATEWAY=test
