# =============================================================================
# نمونه متغیرهای محیطی (فقط توسعه محلی)
# در production، توکن‌ها/تنظیمات در دیتابیس (system_settings / site_settings) ذخیره می‌شوند.
# این فایل را کپی کرده و به .env تغییر نام دهید؛ هرگز کلیدهای واقعی را commit نکنید.
# =============================================================================

# --- اجباری ---
# رشته اتصال PostgreSQL (توصیه: Neon PostgreSQL برای Cloudflare)
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# --- اجباری ---
# رمز JWT (حداقل ۳۲ کاراکتر تصادفی)
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# --- اختیاری: توسعه محلی ---
# توکن ربات تلگرام (اختیاری؛ در production از system_settings استفاده می‌شود)
TELEGRAM_BOT_TOKEN=optional-dev-token

# توکن ربات بله (اختیاری)
BALE_BOT_TOKEN=optional-dev-token

# مرچنت کد درگاه پرداخت (اختیاری؛ در production از system_settings استفاده می‌شود)
PAYMENT_MERCHANT_ID=optional-dev-merchant
